generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Report {
  id                String    @id @default(cuid())
  name              String?
  contact           String?
  location          String
  description       String
  language          Language  @default(unknown)
  category          Category?
  urgency           Urgency?
  summary           String?
  suggestedAction   String?
  confidence        Float?
  possibleDuplicate Boolean   @default(false)
  matchedReportId   String?
  matchedReport     Report?   @relation("DuplicateOf", fields: [matchedReportId], references: [id], onDelete: Cascade)
  duplicates        Report[]  @relation("DuplicateOf")
  status            Status    @default(pending)
  embedding         Unsupported("vector(768)")?  // pgvector column
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

enum Language {
  bn
  en
  unknown
}

enum Category {
  medical
  fire
  accident
  crime
  flood
  utility
  public_service
  infrastructure
  other
}

enum Urgency {
  low
  medium
  high
  critical
}

enum Status {
  pending
  in_review
  assigned
  resolved
  rejected
}
